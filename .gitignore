# Environment — never commit secrets
.env

# Virtual environment
.venv/

# Model artifacts (large binary files)
model/*.pkl
model/*.json

# Local Bronze data lake (generated at runtime — never commit raw data)
data/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store

# Weather HTTP cache (created by openmeteo-requests)
.weather_cache*
.weather_forecast_cache*

# IDE
.vscode/
.idea/

# dbt — credentials and build artefacts (never commit)
dbt/profiles.yml
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Feast — local registry and online store (generated at runtime)
feature_store/data/

# Personal / private docs (never push to GitHub)
docs/

# Platform plan — private notes, interview strategy, business context (NEVER push)
PLATFORM_PLAN.md
PLATFORM_PLAN_old.md
PLATFORM_PLAN*.md

# Skye interview presentation (keep local only)
Skye_Interview_Arnob_Mukherjee.*
old_Skye_Interview_Arnob_Mukherjee.pdf
demo.gif
example.gif
example_frame0.png
make_demo_gif.py
