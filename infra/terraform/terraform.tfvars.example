# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git - it is listed in .gitignore.

project_id   = "your-gcp-project-id"
region       = "europe-north1"
zone         = "europe-north1-a"
environment  = "prod"

gke_node_count   = 2
gke_machine_type = "n1-standard-2"

gcs_bucket_name = "nordspot-bronze"

# Sensitive - supply via TF_VAR_* env vars instead of this file in CI:
#   export TF_VAR_entsoe_api_key="your-key"
#   export TF_VAR_nordspot_api_key="your-key"
entsoe_api_key      = "your-entsoe-api-key"
clickhouse_password = "your-clickhouse-password"
nordspot_api_key    = "your-nordspot-api-key"
