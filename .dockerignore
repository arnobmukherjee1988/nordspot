# ── Virtual environment (never bake into image) ───────────────────────────────
.venv/

# ── Model artefacts (bind-mounted at runtime, not baked in) ──────────────────
model/*.pkl
model/*.json

# ── Local data / caches ───────────────────────────────────────────────────────
*.sqlite
.weather_cache*

# ── Documentation and research artefacts ─────────────────────────────────────
docs/
notebooks/
*.tex
*.pdf
*.aux
*.log
*.nav
*.snm
*.toc
*.out

# ── Demo / media files ────────────────────────────────────────────────────────
*.gif
*.png
make_demo_gif.py

# ── Interview / personal files ────────────────────────────────────────────────
Skye_Interview_*

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Git internals ─────────────────────────────────────────────────────────────
.git/

# ── Secrets (must never enter the build context) ─────────────────────────────
.env
