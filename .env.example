# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ENTSO-E API key -- register at https://transparency.entsoe.eu/usrm/user/myAccountSettings
ENTSOE_API_KEY=your_api_key_here

# ClickHouse connection string
# Local Docker (matches docker-compose.yml defaults):
TIMEDB_CH_URL=http://se3user:se3password@localhost:8123/se3db

# SE3 bidding zone centre coordinates (Stockholm)
SE3_LAT=59.33
SE3_LON=18.07

# How far back to fetch historical data
SE3_TRAIN_START=2020-01-01

# Directory where trained model artefacts are saved
MODEL_DIR=model
