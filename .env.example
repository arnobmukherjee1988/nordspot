# Copy this file to .env and fill in your values
# Never commit .env to git

# ENTSO-E API key — get yours at: https://transparency.entsoe.eu/usrm/user/myAccountSettings
ENTSOE_API_KEY=your-entsoe-api-key-here

# TimeDB — ClickHouse connection string
# When running locally via Docker: use the value below as-is
TIMEDB_CH_URL=clickhouse://se3user:se3password@localhost:8123/se3db

# SE3 bidding zone centre coordinates (Stockholm)
SE3_LAT=59.33
SE3_LON=18.07

# Training start date — how far back to fetch historical data
SE3_TRAIN_START=2020-01-01

# Directory where trained model artifacts are saved
MODEL_DIR=model
