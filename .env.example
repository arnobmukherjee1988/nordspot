# ─────────────────────────────────────────────────────────────────────────────
# NordSpot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data sources ──────────────────────────────────────────────────────────────
# ENTSO-E Transparency Platform API key
# Register at: https://transparency.entsoe.eu/usrm/user/myAccountSettings
ENTSOE_API_KEY=your_entsoe_api_key_here

# ── ClickHouse (local Docker) ─────────────────────────────────────────────────
TIMEDB_CH_URL=http://nordspot:nordspot@localhost:8123/nordspot

# ── Redis (Feast online store) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── GCP (populated when deploying to Google Cloud) ────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=nordspot-bronze
BIGQUERY_DATASET=nordspot_silver
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Feast feature store ───────────────────────────────────────────────────────
FEAST_REPO_PATH=feast/

# ── Model training ────────────────────────────────────────────────────────────
TRAIN_START_DATE=2020-01-01
MODEL_DIR=model

# ── Forecasting zones ─────────────────────────────────────────────────────────
FORECAST_ZONES=SE1,SE2,SE3,SE4

# ── Zone centre coordinates (used for weather fetching) ───────────────────────
SE1_LAT=65.58
SE1_LON=22.15
SE2_LAT=63.83
SE2_LON=20.26
SE3_LAT=59.33
SE3_LON=18.07
SE4_LAT=55.61
SE4_LON=13.00

# ── FastAPI authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_SECRET_KEY=your_secret_key_here
