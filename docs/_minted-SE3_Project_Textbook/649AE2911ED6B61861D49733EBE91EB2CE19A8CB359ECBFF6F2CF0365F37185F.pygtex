    \PYG{p}{)}

    \PYG{n}{df} \PYG{o}{=} \PYG{n}{series}\PYG{o}{.}\PYG{n}{reset\PYGZus{}index}\PYG{p}{()}
    \PYG{n}{df}\PYG{o}{.}\PYG{n}{columns} \PYG{o}{=} \PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}valid\PYGZus{}time\PYGZdq{}}\PYG{p}{,} \PYG{l+s+s2}{\PYGZdq{}value\PYGZdq{}}\PYG{p}{]}           \PYG{c+c1}{\PYGZsh{} tidy format for TimeDB}
    \PYG{n}{df}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}valid\PYGZus{}time\PYGZdq{}}\PYG{p}{]} \PYG{o}{=} \PYG{n}{pd}\PYG{o}{.}\PYG{n}{to\PYGZus{}datetime}\PYG{p}{(}\PYG{n}{df}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}valid\PYGZus{}time\PYGZdq{}}\PYG{p}{],} \PYG{n}{utc}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
