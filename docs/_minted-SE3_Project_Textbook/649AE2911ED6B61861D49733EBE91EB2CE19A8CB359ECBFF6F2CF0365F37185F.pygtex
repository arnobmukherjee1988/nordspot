\PYG{n}{SE3\PYGZus{}ZONE} \PYG{o}{=} \PYG{l+s+s2}{\PYGZdq{}10Y1001A1001A46L\PYGZdq{}}          \PYG{c+c1}{\PYGZsh{} EIC code for SE3 bidding zone}

\PYG{k}{def} \PYG{n+nf}{fetch\PYGZus{}prices}\PYG{p}{(}\PYG{n}{start}\PYG{p}{,} \PYG{n}{end}\PYG{p}{):}
    \PYG{n}{api\PYGZus{}key} \PYG{o}{=} \PYG{n}{os}\PYG{o}{.}\PYG{n}{environ}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}ENTSOE\PYGZus{}API\PYGZus{}KEY\PYGZdq{}}\PYG{p}{]}
    \PYG{n}{client}  \PYG{o}{=} \PYG{n}{EntsoePandasClient}\PYG{p}{(}\PYG{n}{api\PYGZus{}key}\PYG{o}{=}\PYG{n}{api\PYGZus{}key}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Returns a pandas Series indexed by UTC timestamps}
    \PYG{n}{series} \PYG{o}{=} \PYG{n}{client}\PYG{o}{.}\PYG{n}{query\PYGZus{}day\PYGZus{}ahead\PYGZus{}prices}\PYG{p}{(}
        \PYG{n}{SE3\PYGZus{}ZONE}\PYG{p}{,}
